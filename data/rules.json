  "ruleDefinitions": [
    {
      "ruleId": "RULE-001",
      "ruleName": "Quality Status",
      "ruleType": "COMPLIANCE",
      "description": "Only released batches may be allocated",
      "priority": 4,
      "active": true,
      "parameters": {
        "allowedStatuses": [
          "RELEASED"
        ]
      }
    },
    {
      "ruleId": "RULE-002",
      "ruleName": "TRIC Validation",
      "ruleType": "COMPLIANCE",
      "description": "Destination country must be TRIC-approved for the batch",
      "priority": 5,
      "active": true,
      "parameters": {}
    },
    {
      "ruleId": "RULE-003",
      "ruleName": "RMSL Validation",
      "ruleType": "COMPLIANCE",
      "description": "Remaining shelf life must meet country-specific threshold",
      "priority": 6,
      "active": true,
      "parameters": {}
    },
    {
      "ruleId": "RULE-004",
      "ruleName": "Batch Split",
      "ruleType": "COMPLIANCE",
      "description": "Full quantity must be on single batch when splitting not allowed",
      "priority": 7,
      "active": true,
      "parameters": {}
    },
    {
      "ruleId": "RULE-005",
      "ruleName": "Japan Sequence",
      "ruleType": "MARKET_RULES",
      "description": "Continuous batch sequence required for Japan market",
      "priority": 5,
      "active": true,
      "version": 2,
      "parameters": {
        "countryCode": "JP"
      }
    },
    {
      "ruleId": "RULE-006",
      "ruleName": "FIFO Selection",
      "ruleType": "FIFO",
      "description": "Oldest compliant batch selected first (after compliance gates)",
      "priority": 6,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-007",
      "ruleName": "Packing System FG-SO Mapping",
      "ruleType": "COMPLIANCE",
      "description": "Packaging order must map to sales order via packing system",
      "priority": 1,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-008",
      "ruleName": "Quality Stock Check",
      "ruleType": "COMPLIANCE",
      "description": "Only unrestricted released quality stock may be allocated",
      "priority": 2,
      "active": true,
      "version": 1,
      "parameters": {
        "allowedStockTypes": [
          "UNRESTRICTED"
        ]
      }
    },
    {
      "ruleId": "RULE-009",
      "ruleName": "Inspection Lot Release",
      "ruleType": "COMPLIANCE",
      "description": "Batch must have released SAP QM inspection lot (usage decision)",
      "priority": 3,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-010",
      "ruleName": "ATP Check",
      "ruleType": "AVAILABILITY",
      "description": "Available-to-promise quantity must cover order requirement",
      "priority": 1,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-011",
      "ruleName": "Reserved Inventory Check",
      "ruleType": "AVAILABILITY",
      "description": "Batch must not be reserved for conflicting market/order",
      "priority": 2,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-012",
      "ruleName": "Optimization Selection",
      "ruleType": "OPTIMIZATION",
      "description": "Select batch maximizing service level and RMSL margin after compliance",
      "priority": 7,
      "active": true,
      "version": 1,
      "parameters": {}
    },
    {
      "ruleId": "RULE-014",
      "ruleName": "Confirmed Schedule Slot Gate",
      "ruleType": "PRODUCTION",
      "description": "Allocate only when the packaging order has a confirmed Gantt slot (line, planned start/end) from line planning",
      "priority": 1,
      "active": true,
      "version": 1,
      "parameters": {
        "requireConfirmedSchedule": true,
        "allowedPlanningStatuses": [
          "OPTIMIZED",
          "CONFIRMED",
          "VALID"
        ]
      }
    }
