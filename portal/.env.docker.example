# Root env for docker-compose.prod.yml / Portainer "Load variables from .env"

# --- App ---
APP_NAME=Prediction Portal
NODE_ENV=production

# --- Backend ---
BACKEND_PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgres://portal:portal@postgres:5432/portal
REDIS_URL=redis://redis:6379
CORS_ORIGIN=https://portal.example.com
SAAS_ENABLED=false

# --- Frontend build args ---
VITE_APP_URL=https://portal.example.com
VITE_API_URL=
VITE_SENTRY_DSN=

# --- Optional integrations ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com
