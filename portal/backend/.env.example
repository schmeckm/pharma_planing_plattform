NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (sqlite default for local dev)
DATABASE_DIALECT=sqlite
DATABASE_STORAGE=./data/portal.sqlite

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS / Frontend (localhost und 127.0.0.1 für lokale Dev)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://127.0.0.1:5173

# Allocation Engine API (für Statusleiste)
ALLOCATION_API_URL=http://127.0.0.1:8000

# Optional
REDIS_URL=
SAAS_ENABLED=false
SENTRY_DSN=
OPENAI_API_KEY=

# Google SSO (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@localhost
