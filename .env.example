# Hard Allocation Platform — Backend
PORT=8000
HOST=0.0.0.0
HAP_DATA_DIR=./data
HAP_DATA_PROVIDER=json

# Rule-based agents (always on unless disabled)
AGENTS_ENABLED=true

# ── LLM Agents (OpenAI or Azure OpenAI) ─────────────────────────────
# Set OPENAI_API_KEY or AZURE_OPENAI_* to enable real LLM agents.
LLM_PROVIDER=openai
# rules-only | hybrid | full
COPILOT_MODE=hybrid
AGENT_LLM_ENABLED=true

# OpenAI direct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (enterprise / GxP)
# LLM_PROVIDER=azure-openai
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# RAG learning from audit + planner feedback
RAG_ENABLED=true
RAG_TOP_K=8
RAG_MAX_CHUNKS=2000
RAG_AUDIT_LIMIT=300
LLM_FALLBACK_TO_RULES=true
LLM_MAX_TOKENS=2048
# LLM_LOG_PROMPTS=true

# Event bus (optional)
# HAP_EVENT_BUS=kafka
# KAFKA_BROKERS=localhost:9092

# ── Scheduling (production: OR-Tools CP-SAT sidecar) ───────────────
# heuristic = dev/small plants | ortools = 80+ orders/day (500+ recommended)
SCHEDULING_OPTIMIZER=ortools
ORTOOLS_URL=http://127.0.0.1:8010
ORTOOLS_PORT=8010
# Set true in production so failed sidecar does not silently fall back to heuristic
ORTOOLS_REQUIRED=false
ORTOOLS_TIMEOUT_MS=200000
ORTOOLS_MAX_TIME_SECONDS=180
ORTOOLS_NUM_WORKERS=8
ORTOOLS_LINE_SCORE_WEIGHT=8
ORTOOLS_LINE_BALANCE_WEIGHT=15
SCHEDULING_HORIZON_DAYS=14
# Control Tower / Digital Twin (?horizon=) — Presets in UI
CONTROL_TOWER_HORIZON_DEFAULT=7
CONTROL_TOWER_HORIZON_OPTIONS=7,30,90
# OEE / Leistungsfaktor: kurz vs. lang (Schwellwert für Sequencing)
PERFORMANCE_SHORT_HORIZON_DAYS=30
PERFORMANCE_LONG_HORIZON_DAYS=365
PERFORMANCE_HORIZON_LONG_THRESHOLD=14
SCHEDULING_CACHE_TTL_MS=300000
SCHEDULING_MAX_HEURISTIC_ORDERS=80
SCHEDULING_PERSIST_SCENARIOS=false

# Phase 5 — SAP operations import + multi work-center OR-Tools scheduling
# ortools | heuristic | off
OPERATIONS_SOLVER=ortools
OPERATIONS_ORTOOLS_REQUIRED=false

# Shadow-Planning (Phase 1): Entwürfe in draftSchedules.json — produktive Orders erst via activate-draft
SHADOW_PLANNING=true

# Kombinierte Vor-/Rückwärtsplanung (Liefertermin rückwärts + Freigabe/Charge vorwärts)
COMBINED_PLANNING=true
PLANNING_DELIVERY_BUFFER_DAYS=2
PLANNING_QA_BUFFER_DAYS=0
PLANNING_HOURS_PER_DAY=8

# ── Live JSON cache (Phase D) ─────────────────────────────────────────
# Keeps parsed JSON in RAM; invalidates on file mtime change or write.
HAP_LIVE_CACHE=true
HAP_LIVE_CACHE_WARMUP=true
