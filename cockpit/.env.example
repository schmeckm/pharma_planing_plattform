# Dev server port (default: 3001)
VITE_DEV_PORT=3001
# Mock data enabled by default — set to false to use Node.js backend
VITE_USE_MOCK=false
# API proxy target (must match backend PORT — use 8010 if port 8000 is occupied by other apps)
VITE_API_PROXY=http://127.0.0.1:8000
VITE_API_BASE_URL=/api/v1
