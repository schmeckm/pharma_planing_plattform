{
  "name": "hard-allocation-platform",
  "version": "2.0.0",
  "description": "Pharmaceutical Hard Allocation Platform MVP - Node.js",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:8010": "node -e \"process.env.PORT='8010';require('./server.js')\"",
    "dev": "node --watch server.js",
    "dev:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1 dev",
    "stop:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1 stop",
    "status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1 status",
    "docker:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1 docker",
    "docker:down": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1 docker:down",
    "test:smoke": "node scripts/smoke-mvp2.js",
    "test:e2e": "node scripts/e2e-platform.js",
    "test": "npm run test:smoke && npm run test:e2e",
    "generate:data": "node scripts/generate-demo-data.js",
    "generate:data:large": "node scripts/generate-demo-data.js 120 200",
    "reset:demo": "node scripts/reset-demo-environment.js",
    "build:backend": "tsc -p backend/tsconfig.json",
    "dev:backend": "tsx watch backend/src/server.ts",
    "seed": "tsx backend/scripts/seed.ts",
    "reset-data": "tsx backend/scripts/reset-data.ts",
    "prestart": "npm run build:backend"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
